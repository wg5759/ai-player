{
  "name": "ai-player",
  "version": "0.6.1",
  "author": "AIPlayer",
  "description": "AI媒体中枢 - 会动手的播放器（桌面+Web双端）",
  "main": "electron/main.js",
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:web": "node scripts/build-web.mjs",
    "build:electron": "pnpm build:web && pnpm build:electron:lean && pnpm build:electron:local-ai",
    "build:electron:lean": "node scripts/build-voice-helper.mjs && electron-builder --config electron-builder.lean.yml",
    "build:electron:local-ai": "node scripts/build-voice-helper.mjs && electron-builder",
    "preview": "vite preview",
    "platform:report": "node scripts/platform-capability-report.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "release:public:verify": "node scripts/verify-public-release-readiness.mjs",
    "release:public:verify:binary": "node scripts/verify-public-release-readiness.mjs --binary",
    "security:scan": "node scripts/security-release-scan.mjs --history",
    "security:scan:packaged": "node scripts/security-release-scan.mjs --history --packaged",
    "test": "node --test tests/*.test.js tests/*.test.mjs",
    "check": "pnpm exec tsc --noEmit && pnpm exec eslint src --max-warnings=0 && pnpm security:scan && pnpm release:public:verify && pnpm test && pnpm build:web"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "exceljs": "4.4.0",
    "formidable": "^3.5.4",
    "mammoth": "^1.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "28.3.3",
    "electron-builder": "^25.1.8",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.aiplayer.app",
    "productName": "AI播放器",
    "asar": true,
    "compression": "normal",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin/win",
        "to": "bin/win",
        "filter": [
          "mpv.exe",
          "mpv.com",
          "vulkan-1.dll",
          "ai-player-voice.exe"
        ]
      },
      {
        "from": "resources/ai-runtime/win-x64",
        "to": "ai-runtime/win-x64",
        "filter": [
          "llama-server.exe",
          "*.dll"
        ]
      },
      {
        "from": "resources/models/Qwen2.5-0.5B-Instruct-Q4_0.gguf",
        "to": "models/Qwen2.5-0.5B-Instruct-Q4_0.gguf"
      },
      {
        "from": "resources/bundled-ai-manifest.json",
        "to": "bundled-ai-manifest.json"
      },
      {
        "from": "resources/licenses",
        "to": "licenses",
        "filter": [
          "llama.cpp/**/*",
          "mpv/**/*",
          "qwen2.5-0.5b/LICENSE",
          "qwen2.5-0.5b/README.md"
        ]
      },
      {
        "from": "LICENSE",
        "to": "legal/LICENSE"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "legal/THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "PRIVACY.md",
        "to": "legal/PRIVACY.md"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icons/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icons/app-icon.ico",
      "uninstallerIcon": "resources/icons/app-icon.ico",
      "artifactName": "AI播放器本地AI版安装包-${version}.${ext}"
    }
  },
  "pnpm": {
    "overrides": {
      "exceljs>uuid": "11.1.1"
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
